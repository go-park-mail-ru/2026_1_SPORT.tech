erDiagram
    user ||--|| user_profile : ""
    user ||--o| admin_profile : ""
    user ||--o| trainer_details : ""
    user ||--o| client_details : ""
    user ||--o{ session : ""

    user ||--o{ trainer_to_sport_type : ""
    sport_type ||--o{ trainer_to_sport_type : ""

    user ||--o{ subscription_tier : ""
    subscription_tier ||--o{ subscription_tier_feature : ""
    feature_dictionary ||--o{ subscription_tier_feature : ""

    user ||--o{ user_subscription : ""
    subscription_tier ||--o{ user_subscription : ""

    user ||--o{ post : ""
    subscription_tier ||--o{ post : ""
    post ||--o{ post_attachment : ""

    user ||--o{ chat : ""
    user ||--o{ chat : ""
    chat ||--o{ message : ""
    user ||--o{ message : ""
    message ||--o{ message_attachment : ""

    post ||--o{ comment : ""
    user ||--o{ comment : ""
    comment ||--o{ comment : ""

    post ||--o{ post_like : ""
    user ||--o{ post_like : ""

    user ||--o{ notification : ""

    user {
        bigint user_id PK
        text email UK "NOT NULL"
        text password_hash "NOT NULL"
        timestamptz created_at "NOT NULL"
        timestamptz updated_at "NOT NULL"
    }

    user_profile {
        bigint user_id PK, FK "-> user.user_id"
        text username UK "NOT NULL"
        text first_name "NOT NULL"
        text last_name "NOT NULL"
        text bio "NULL"
        text avatar_url "NULL"
        timestamptz created_at "NOT NULL"
        timestamptz updated_at "NOT NULL"
    }

    admin_profile {
        bigint admin_id PK, FK "-> user.user_id"
        timestamptz created_at "NOT NULL"
        timestamptz updated_at "NOT NULL"
    }

    trainer_details {
        bigint trainer_user_id PK, FK "-> user.user_id"
        text education_degree "NULL"
        integer total_experience_years "NULL, CHECK (total_experience_years >= 0)"
        timestamptz created_at "NOT NULL"
        timestamptz updated_at "NOT NULL"
    }

    client_details {
        bigint client_id PK, FK "-> user.user_id"
        text fitness_goal "NULL"
        timestamptz created_at "NOT NULL"
        timestamptz updated_at "NOT NULL"
    }

    session {
        text session_id_hash PK
        bigint user_id FK "NOT NULL -> user.user_id"
        timestamptz created_at "NOT NULL"
        timestamptz updated_at "NOT NULL"
        timestamptz expires_at "NOT NULL"
        timestamptz last_seen_at "NOT NULL"
        timestamptz revoked_at "NULL"
        inet ip "NULL"
        text user_agent "NULL"
    }

    sport_type {
        bigint sport_type_id PK
        text name UK "NOT NULL"
        timestamptz created_at "NOT NULL"
        timestamptz updated_at "NOT NULL"
    }

    trainer_to_sport_type {
        bigint trainer_id PK, FK "-> user.user_id"
        bigint sport_type_id PK, FK "-> sport_type.sport_type_id"
        integer experience_years "NULL, CHECK (experience_years >= 0)"
        text sports_rank "NULL"
        timestamptz created_at "NOT NULL"
        timestamptz updated_at "NOT NULL"
    }

    subscription_tier {
        bigint subscription_tier_id PK
        bigint trainer_id FK "NOT NULL -> user.user_id"
        text title "NOT NULL"
        text description "NULL"
        text price_currency "NOT NULL"
        bigint price_value "NOT NULL, CHECK (price_value >= 0)"
        integer price_factor "NOT NULL, CHECK (price_factor >= 0)"
        integer level_rank "NOT NULL, CHECK (level_rank > 0)"
        timestamptz created_at "NOT NULL"
        timestamptz updated_at "NOT NULL"
    }

    feature_dictionary {
        bigint feature_id PK
        text code_name UK "NOT NULL"
        text description "NOT NULL"
        timestamptz created_at "NOT NULL"
        timestamptz updated_at "NOT NULL"
    }

    subscription_tier_feature {
        bigint subscription_tier_id PK, FK "-> subscription_tier.subscription_tier_id"
        bigint feature_id PK, FK "-> feature_dictionary.feature_id"
        timestamptz created_at "NOT NULL"
        timestamptz updated_at "NOT NULL"
    }

    user_subscription {
        bigint user_subscription_id PK
        bigint subscriber_user_id FK "NOT NULL -> user.user_id"
        bigint subscription_tier_id FK "NOT NULL -> subscription_tier.subscription_tier_id"
        timestamptz started_at "NOT NULL"
        timestamptz expires_at "NOT NULL"
        timestamptz created_at "NOT NULL"
        timestamptz updated_at "NOT NULL"
    }

    post {
        bigint post_id PK
        bigint trainer_id FK "NOT NULL -> user.user_id"
        bigint min_tier_id FK "NULL -> subscription_tier.subscription_tier_id"
        text title "NOT NULL"
        text text_content "NOT NULL"
        timestamptz created_at "NOT NULL"
        timestamptz updated_at "NOT NULL"
    }

    post_attachment {
        bigint post_attachment_id PK
        bigint post_id FK "NOT NULL -> post.post_id"
        text file_url "NOT NULL"
        text kind "NOT NULL, CHECK (kind IN ('image','video','document'))"
        timestamptz created_at "NOT NULL"
        timestamptz updated_at "NOT NULL"
    }

    chat {
        bigint chat_id PK
        bigint client_id FK "NOT NULL -> user.user_id"
        bigint trainer_id FK "NOT NULL -> user.user_id"
        bigint client_last_read_message_id FK "NULL -> message.message_id"
        bigint trainer_last_read_message_id FK "NULL -> message.message_id"
        timestamptz created_at "NOT NULL"
        timestamptz updated_at "NOT NULL"
    }

    message {
        bigint message_id PK
        bigint chat_id FK "NOT NULL -> chat.chat_id"
        bigint sender_id FK "NOT NULL -> user.user_id"
        text text_content "NULL"
        timestamptz created_at "NOT NULL"
        timestamptz updated_at "NOT NULL"
    }

    message_attachment {
        bigint message_attachment_id PK
        bigint message_id FK "NOT NULL -> message.message_id"
        text file_url "NOT NULL"
        text kind "NOT NULL, CHECK (kind IN ('image','video','document'))"
        timestamptz created_at "NOT NULL"
        timestamptz updated_at "NOT NULL"
    }

    comment {
        bigint comment_id PK
        bigint post_id FK "NOT NULL -> post.post_id"
        bigint author_id FK "NOT NULL -> user.user_id"
        bigint parent_comment_id FK "NULL -> comment.comment_id"
        text text_content "NOT NULL"
        timestamptz created_at "NOT NULL"
        timestamptz updated_at "NOT NULL"
    }

    post_like {
        bigint post_id PK, FK "NOT NULL -> post.post_id"
        bigint user_id PK, FK "NOT NULL -> user.user_id"
        timestamptz created_at "NOT NULL"
        timestamptz updated_at "NOT NULL"
    }

    notification {
        bigint notification_id PK
        bigint user_id FK "NOT NULL -> user.user_id"
        boolean is_read "NOT NULL"
        timestamptz created_at "NOT NULL"
        timestamptz updated_at "NOT NULL"
        jsonb payload "NOT NULL"
    }
    